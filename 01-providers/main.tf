# ============================================================
# Урок 01: Провайдеры
# ============================================================
#
# Этот файл — аналог playbook в Ansible.
# Но вместо "сделай шаг 1, потом шаг 2" мы описываем
# ЖЕЛАЕМОЕ СОСТОЯНИЕ: "должен быть образ nginx и контейнер из него".
# Terraform сам разберётся в каком порядке это создавать.

# ------------------------------------------------------------
# Блок terraform — указываем какие провайдеры нужны и их версии.
# Аналогия: requirements.yml в Ansible
# ------------------------------------------------------------
terraform {
  required_providers {
    docker = {
      source  = "kreuzwerker/docker" # реестр/имя провайдера
      version = "~> 3.0"             # версия (~ = совместимая)
    }
  }
}

# ------------------------------------------------------------
# Настройка провайдера.
# Аналогия: переменные подключения в inventory (ansible_host, ansible_user...)
# Для локального Docker ничего указывать не нужно — он найдёт сокет сам.
# ------------------------------------------------------------
provider "docker" {}

# ------------------------------------------------------------
# Ресурс: docker_image
# Аналогия: таск "docker_image" в Ansible, но декларативный.
# Мы не говорим "скачай образ" — мы говорим "образ должен существовать".
# ------------------------------------------------------------
resource "docker_image" "nginx" {
  name         = "nginx:alpine"
  keep_locally = true # не удалять образ при terraform destroy
}

# ------------------------------------------------------------
# Ресурс: docker_container
# Аналогия: таск "docker_container" в Ansible.
# Terraform сам поймёт, что сначала нужен образ, потом контейнер
# (благодаря ссылке docker_image.nginx.image_id).
# ------------------------------------------------------------
resource "docker_container" "nginx" {
  name  = "learn-terraform-nginx"
  image = docker_image.nginx.image_id

  ports {
    internal = 80   # порт внутри контейнера
    external = 8080 # порт на хосте — открой http://localhost:8080
  }
}
